# --- STAGE 1: BUILD ---
FROM golang:1.21-alpine AS builder

WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download

COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -o apex-tui ./cmd/apex-tui/main.go

# --- STAGE 2: RUNTIME ---
FROM alpine:latest

WORKDIR /root/
COPY --from=builder /app/apex-tui .

# Ensure the config directory exists for mounting
RUN mkdir -p /root/.config

ENTRYPOINT ["./apex-tui"]
